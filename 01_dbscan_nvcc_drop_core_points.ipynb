    "if USE_GOOGLE_DRIVE:\n",
    "    try:\n",
    "        from google.colab import drive\n",
    "        drive.mount(\"/content/drive\")\n",
    "        BASE_DIR = DRIVE_PROJECT_DIR\n",
    "    except Exception as exc:\n",
    "        print(\"Google Drive nao montado; usando diretorio local.\")\n",
    "        print(\"Motivo:\", repr(exc))\n",
