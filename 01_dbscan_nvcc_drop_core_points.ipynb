    "    HAS_CUML = True\n",
    "    print(\"RAPIDS/cuML disponivel. Baseline: cuML.\")\n",
    "except Exception as exc:\n",
    "    print(\"RAPIDS/cuML nao disponivel. Alternativa do baseline: sklearn CPU.\")\n",
