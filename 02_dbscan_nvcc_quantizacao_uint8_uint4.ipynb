    "N_REPEATS = 3\n",
    "WARMUP_N = min(2000, N)\n",
    "\n",
    "print(\"Warm-up baseline em amostra:\", WARMUP_N)\n",
    "_ = run_baseline_dbscan(X[:WARMUP_N], EPS, MIN_SAMPLES)\n",
    "\n",
    "warmup_input = \"warmup_quant_f32.bin\"\n",
    "X[:WARMUP_N].astype(np.float32).tofile(warmup_input)\n",
    "try:\n",
    "    stdout, _ = run_cuda_binary([\"./dbscan_quantized\", warmup_input, \"warmup_quant_labels.bin\", str(WARMUP_N), str(D), str(EPS), str(MIN_SAMPLES), \"f32\"])\n",
    "    print(\"Warm-up CUDA concluido.\")\n",
    "except Exception as exc:\n",
    "    print(\"Warm-up CUDA falhou, mas o benchmark principal continuara:\", repr(exc))\n",
    "\n",
    "baseline_rows = []\n",
    "baseline_labels_ref = None\n",
    "baseline_version = None\n",
    "for repeat in range(N_REPEATS):\n",
    "    labels, elapsed, backend = run_baseline_dbscan(X, EPS, MIN_SAMPLES)\n",
    "    if baseline_labels_ref is None:\n",
    "        baseline_labels_ref = labels\n",
    "        baseline_version = f\"baseline_{backend}\"\n",
    "    baseline_rows.append({\n",
    "        \"dataset_name\": DATASET_NAME,\n",
    "        \"n_samples\": N,\n",
    "        \"n_features\": D,\n",
    "        \"versao\": f\"baseline_{backend}\",\n",
    "        \"modo\": \"baseline\",\n",
    "        \"repeat\": repeat,\n",
    "        \"status\": \"ok\",\n",
    "        \"motivo_falha\": \"\",\n",
    "        \"bytes_por_atributo_aprox\": 4.0,\n",
    "        \"dimensao_original\": D,\n",
    "        \"dimensao_empacotada\": np.nan,\n",
    "        \"core_points\": np.nan,\n",
    "        \"noise\": int(np.sum(labels == -1)),\n",
    "        \"noise_%\": noise_percent(labels),\n",
    "        \"time_s_wall\": elapsed,\n",
    "        \"total_cuda_event_s\": np.nan,\n",
    "        \"clusters\": count_clusters(labels),\n",
    "        \"ARI_vs_baseline\": adjusted_rand_score(baseline_labels_ref, labels),\n",
    "        \"NMI_vs_baseline\": normalized_mutual_info_score(baseline_labels_ref, labels),\n",
    "        \"ARI_vs_cuda_float32\": np.nan,\n",
    "        \"NMI_vs_cuda_float32\": np.nan,\n",
    "        \"eps2_q\": np.nan,\n",
    "    })\n",
    "\n",
    "PACKED_D = (D + 1) // 2\n",
    "cuda_runs = [\n",
    "    (\"cuda_cpp_float32\", \"f32\", 4.0, D),\n",
    "    (\"cuda_cpp_uint8\", \"u8\", 1.0, D),\n",
    "    (\"cuda_cpp_uint4_packed\", \"u4\", 0.5, PACKED_D),\n",
    "]\n",
    "\n",
    "rows = list(baseline_rows)\n",
    "all_labels = {baseline_version: baseline_labels_ref}\n",
    "labels_cuda_float32_ref = None\n",
    "\n",
    "for version, mode, bytes_attr, packed_d in cuda_runs:\n",
    "    for repeat in range(N_REPEATS):\n",
    "        out_file = f\"{DATASET_NAME}_{N}_{version}_r{repeat}.bin\"\n",
    "        cmd = [\"./dbscan_quantized\", INPUT_BIN, out_file, str(N), str(D), str(EPS), str(MIN_SAMPLES), mode]\n",
    "        try:\n",
    "            stdout, wall_time = run_cuda_binary(cmd)\n",
    "            print(\"\\n---\", version, \"repeat\", repeat, \"---\")\n",
    "            print(stdout)\n",
    "            metrics = parse_key_values_stdout(stdout)\n",
    "            labels = relabel_consecutive(np.fromfile(out_file, dtype=np.int32, count=N))\n",
    "            if version == \"cuda_cpp_float32\" and labels_cuda_float32_ref is None:\n",
    "                labels_cuda_float32_ref = labels.copy()\n",
    "            if repeat == 0:\n",
    "                all_labels[version] = labels\n",
    "            rows.append({\n",
    "                \"dataset_name\": DATASET_NAME,\n",
    "                \"n_samples\": N,\n",
    "                \"n_features\": D,\n",
    "                \"versao\": version,\n",
    "                \"modo\": str(metrics.get(\"mode\", mode)),\n",
    "                \"repeat\": repeat,\n",
    "                \"status\": \"ok\",\n",
    "                \"motivo_falha\": \"\",\n",
    "                \"bytes_por_atributo_aprox\": bytes_attr,\n",
    "                \"dimensao_original\": D,\n",
    "                \"dimensao_empacotada\": packed_d,\n",
    "                \"core_points\": int(metrics.get(\"core_points\", 0)),\n",
    "                \"noise\": int(metrics.get(\"noise\", np.sum(labels == -1))),\n",
    "                \"noise_%\": noise_percent(labels),\n",
    "                \"time_s_wall\": wall_time,\n",
    "                \"total_cuda_event_s\": float(metrics.get(\"total\", np.nan)),\n",
    "                \"clusters\": count_clusters(labels),\n",
    "                \"ARI_vs_baseline\": adjusted_rand_score(baseline_labels_ref, labels),\n",
    "                \"NMI_vs_baseline\": normalized_mutual_info_score(baseline_labels_ref, labels),\n",
    "                \"ARI_vs_cuda_float32\": np.nan,\n",
    "                \"NMI_vs_cuda_float32\": np.nan,\n",
    "                \"eps2_q\": int(metrics.get(\"eps2_q\", -1)),\n",
    "            })\n",
    "        except Exception as exc:\n",
    "            rows.append({\n",
    "                \"dataset_name\": DATASET_NAME,\n",
    "                \"n_samples\": N,\n",
    "                \"n_features\": D,\n",
    "                \"versao\": version,\n",
    "                \"modo\": mode,\n",
    "                \"repeat\": repeat,\n",
    "                \"status\": \"falhou\",\n",
    "                \"motivo_falha\": str(exc)[:200],\n",
    "            })\n",
    "\n",
    "rows.append({\n",
    "    \"dataset_name\": DATASET_NAME,\n",
    "    \"n_samples\": N,\n",
    "    \"n_features\": D,\n",
    "    \"versao\": \"cuda_cpp_uint8_dp4a\",\n",
    "    \"modo\": \"dp4a\",\n",
    "    \"repeat\": np.nan,\n",
    "    \"status\": \"nao_implementado\",\n",
    "    \"motivo_falha\": \"DP4A deixado como experimento futuro para nao quebrar o notebook; requer quantizacao int8 e kernels especificos.\",\n",
    "    \"bytes_por_atributo_aprox\": 1.0,\n",
    "    \"dimensao_original\": D,\n",
    "    \"dimensao_empacotada\": D,\n",
    "})\n",
    "\n",
    "df_results = pd.DataFrame(rows)\n",
    "\n",
    "if labels_cuda_float32_ref is not None:\n",
    "    for idx, row in df_results[df_results[\"status\"] == \"ok\"].iterrows():\n",
    "        versao = row[\"versao\"]\n",
    "        if versao in all_labels:\n",
    "            labels = all_labels[versao]\n",
    "            df_results.loc[idx, \"ARI_vs_cuda_float32\"] = adjusted_rand_score(labels_cuda_float32_ref, labels)\n",
    "            df_results.loc[idx, \"NMI_vs_cuda_float32\"] = normalized_mutual_info_score(labels_cuda_float32_ref, labels)\n",
    "    baseline_mask = df_results[\"versao\"].astype(str).str.startswith(\"baseline_\") & (df_results[\"status\"] == \"ok\")\n",
    "    df_results.loc[baseline_mask, \"ARI_vs_cuda_float32\"] = adjusted_rand_score(labels_cuda_float32_ref, baseline_labels_ref)\n",
    "    df_results.loc[baseline_mask, \"NMI_vs_cuda_float32\"] = normalized_mutual_info_score(labels_cuda_float32_ref, baseline_labels_ref)\n",
    "\n",
    "df_results[\"time_s_wall_median\"] = np.nan\n",
    "df_results[\"total_cuda_event_s_median\"] = np.nan\n",
    "df_results[\"speedup_vs_cuda_float32_event_median\"] = np.nan\n",
    "df_results[\"speedup_vs_cuda_float32_wall_median\"] = np.nan\n",
    "df_results[\"speedup_vs_baseline_wall_median\"] = np.nan\n",
    "\n",
    "ok = df_results[\"status\"] == \"ok\"\n",
    "for versao, group in df_results[ok].groupby(\"versao\"):\n",
    "    wall_med = group[\"time_s_wall\"].median()\n",
    "    event_med = group[\"total_cuda_event_s\"].median()\n",
    "    df_results.loc[df_results[\"versao\"] == versao, \"time_s_wall_median\"] = wall_med\n",
    "    df_results.loc[df_results[\"versao\"] == versao, \"total_cuda_event_s_median\"] = event_med\n",
    "\n",
    "baseline_wall = df_results.loc[baseline_mask, \"time_s_wall\"].median()\n",
    "float32_mask = (df_results[\"versao\"] == \"cuda_cpp_float32\") & ok\n",
    "float32_wall = df_results.loc[float32_mask, \"time_s_wall\"].median()\n",
    "float32_event = df_results.loc[float32_mask, \"total_cuda_event_s\"].median()\n",
    "\n",
    "for versao, group in df_results[ok].groupby(\"versao\"):\n",
    "    wall_med = group[\"time_s_wall\"].median()\n",
    "    event_med = group[\"total_cuda_event_s\"].median()\n",
    "    mask = df_results[\"versao\"] == versao\n",
    "    if pd.notna(baseline_wall) and wall_med > 0:\n",
    "        df_results.loc[mask, \"speedup_vs_baseline_wall_median\"] = baseline_wall / wall_med\n",
    "    if pd.notna(float32_wall) and wall_med > 0:\n",
    "        df_results.loc[mask, \"speedup_vs_cuda_float32_wall_median\"] = float32_wall / wall_med\n",
    "    if pd.notna(float32_event) and pd.notna(event_med) and event_med > 0:\n",
    "        df_results.loc[mask, \"speedup_vs_cuda_float32_event_median\"] = float32_event / event_med\n",
    "\n",
    "output_csv = RESULTS_DIR / f\"resultados_quantizacao_{DATASET_NAME}_{N}.csv\"\n",
    "df_results.to_csv(output_csv, index=False)\n",
    "print_table(df_results.round(4), \"Tabela final - quantizacao com repeats e mediana\")\n",
    "print(\"CSV salvo em:\", output_csv)"
   ],
